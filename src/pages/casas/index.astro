---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Casas Prefabricadas — Nido">
  <section class="container mx-auto px-4 py-16">
    <h1 class="font-display text-4xl text-ink mb-4">Casas Prefabricadas</h1>
    <p class="text-muted mb-8">Diseños modernos y sustentables para tu hogar.</p>
    <!-- Product grid placeholder — populated in catalog phase -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-surface rounded p-6 border border-bg/50">
        <p class="text-muted text-sm">Proyectos próximamente</p>
      </div>
    </div>
  </section>
</Layout>
