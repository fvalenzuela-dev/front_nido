---
import Layout from '@/layouts/Layout.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import EmptyState from '@/components/ui/EmptyState.astro'
import Button from '@/components/ui/Button.astro'
---

<Layout title="Paneles SIP — Nido">
  <section class="bg-bg">
    <div class="container mx-auto px-4 py-16">
      <h1 class="sr-only">Catálogo de paneles SIP</h1>
      <SectionHeader
        eyebrow="Catálogo"
        title="Paneles SIP"
        description="Paneles estructurales de alta eficiencia térmica para construcción sustentable. Consulta disponibilidad y solicita una cotización personalizada."
      />

      <!-- Grilla de productos — se poblará en la fase de catálogo -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="col-span-full">
          <EmptyState
            title="Catálogo en preparación"
            description="Estamos cargando nuestro catálogo de paneles SIP. Mientras tanto, puedes solicitar información directamente con nuestro equipo."
          >
            <Fragment slot="icon">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="2" y="3" width="20" height="14" rx="2" />
                <path d="M8 21h8M12 17v4" />
              </svg>
            </Fragment>
            <Button href="/contacto" variant="primary" size="md">
              Solicitar información
            </Button>
          </EmptyState>
        </div>
      </div>
    </div>
  </section>
</Layout>
