---
export const prerender = false

import AdminLayout from '@/layouts/AdminLayout.astro'
import { panelFormErrorMessage } from '@/lib/panel-form'

const errorMessage = panelFormErrorMessage(Astro.url.searchParams.get('error'))

const inputClass =
  'w-full rounded border border-bg/60 bg-surface text-ink px-3 py-2 ' +
  'focus:outline-none focus:border-primary'
const labelClass = 'block text-sm text-muted mb-1'
---

<AdminLayout title="Nuevo panel SIP — Admin — Nido">
  <div class="flex items-center justify-between mb-6">
    <h1 class="font-display text-3xl text-ink">Nuevo panel SIP</h1>
    <a href="/admin/productos" class="text-sm text-muted hover:text-ink">← Volver</a>
  </div>

  {errorMessage && (
    <div class="bg-secondary/10 border border-secondary/40 text-ink rounded p-3 mb-6 text-sm" role="alert">
      {errorMessage}
    </div>
  )}

  <form method="POST" action="/api/admin/panels" class="bg-surface rounded border border-bg/50 p-6 max-w-2xl flex flex-col gap-5">
    <div>
      <label class={labelClass} for="nombre">Nombre <span class="text-secondary">*</span></label>
      <input class={inputClass} id="nombre" name="nombre" type="text" required maxlength="200" />
    </div>

    <div>
      <label class={labelClass} for="descripcion">Descripción</label>
      <textarea class={inputClass} id="descripcion" name="descripcion" rows="3"></textarea>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class={labelClass} for="espesor_mm">Espesor (mm) <span class="text-secondary">*</span></label>
        <input class={inputClass} id="espesor_mm" name="espesor_mm" type="number" min="1" step="1" required />
      </div>
      <div>
        <label class={labelClass} for="ancho_mm">Ancho (mm)</label>
        <input class={inputClass} id="ancho_mm" name="ancho_mm" type="number" min="1" step="1" value="1220" />
      </div>
      <div>
        <label class={labelClass} for="largo_mm">Largo (mm)</label>
        <input class={inputClass} id="largo_mm" name="largo_mm" type="number" min="1" step="1" value="2440" />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class={labelClass} for="r_value">R-value</label>
        <input class={inputClass} id="r_value" name="r_value" type="number" min="0" step="0.01" />
      </div>
      <div>
        <label class={labelClass} for="peso_kg_m2">Peso (kg/m²)</label>
        <input class={inputClass} id="peso_kg_m2" name="peso_kg_m2" type="number" min="0" step="0.01" />
      </div>
      <div>
        <label class={labelClass} for="precio_clp">Precio (CLP)</label>
        <input class={inputClass} id="precio_clp" name="precio_clp" type="number" min="0" step="1" />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 items-end">
      <div>
        <label class={labelClass} for="stock">Stock</label>
        <input class={inputClass} id="stock" name="stock" type="number" min="0" step="1" value="0" />
      </div>
      <label class="flex items-center gap-2 text-sm text-ink pb-2">
        <input id="publicado" name="publicado" type="checkbox" class="rounded border-bg/60" />
        Publicar de inmediato
      </label>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <button
        type="submit"
        data-submit
        class="bg-primary text-white px-6 py-2.5 rounded hover:bg-primary/90 disabled:opacity-60"
      >
        Crear panel SIP
      </button>
      <a href="/admin/productos" class="text-sm text-muted hover:text-ink">Cancelar</a>
    </div>
  </form>

  <script>
    // Progressive enhancement: estado de carga al enviar (sin React, CLAUDE.md §2).
    const form = document.querySelector('form')
    const submit = document.querySelector('[data-submit]') as HTMLButtonElement | null
    form?.addEventListener('submit', () => {
      if (submit) {
        submit.disabled = true
        submit.textContent = 'Guardando…'
      }
    })
  </script>
</AdminLayout>
