---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Cotización — Nido">
  <section class="container mx-auto px-4 py-16 max-w-2xl">
    <h1 class="font-display text-4xl text-ink mb-4">Cotización</h1>
    <p class="text-muted mb-8">
      Completa el formulario y nos ponemos en contacto a la brevedad.
    </p>
    <!-- Contact form placeholder — implemented in forms phase -->
    <div class="bg-surface rounded p-8 border border-bg/50">
      <p class="text-muted text-sm">Formulario de cotización próximamente</p>
    </div>
  </section>
</Layout>
