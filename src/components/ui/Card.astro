---
import { cn } from '../../lib/cn'

interface Props {
  hover?: boolean
  class?: string
}

const { hover = false, class: className } = Astro.props

const classes = cn(
  'bg-surface rounded border border-border p-6',
  hover && 'shadow-card hover:-translate-y-0.5 transition-all duration-200',
  className
)
---

<div class={classes}>
  <slot />
</div>
