---
import { cn } from '../../lib/cn'

interface Props {
  eyebrow?: string
  title: string
  description?: string
  align?: 'left' | 'center'
  class?: string
}

const { eyebrow, title, description, align = 'left', class: className } = Astro.props

const wrapperClasses = cn(
  'mb-10',
  align === 'center' && 'text-center',
  className
)
---

<div class={wrapperClasses}>
  {eyebrow && (
    <p class="uppercase tracking-wide text-xs font-semibold text-primary mb-2">
      {eyebrow}
    </p>
  )}
  <h2 class="font-display text-3xl sm:text-4xl text-ink leading-tight">
    {title}
  </h2>
  {description && (
    <p class={cn('text-muted mt-3 max-w-2xl', align === 'center' && 'mx-auto')}>
      {description}
    </p>
  )}
</div>
