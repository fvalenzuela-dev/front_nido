---
import { cn } from '../../lib/cn'

interface Props {
  eyebrow?: string
  title: string
  subtitle?: string
  class?: string
}

const { eyebrow, title, subtitle, class: className } = Astro.props

const wrapperClasses = cn(
  'container mx-auto px-4 py-24 lg:py-32',
  className
)
---

<div class={wrapperClasses}>
  <div class="grid lg:grid-cols-[55fr_45fr] gap-12 items-center">
    <!-- Columna de texto: 55% -->
    <div class="flex flex-col gap-6">
      {eyebrow && (
        <p class="uppercase tracking-wide text-xs font-semibold text-primary">
          {eyebrow}
        </p>
      )}
      <h1 class="font-display italic text-4xl sm:text-5xl lg:text-6xl leading-tight text-ink hyphens-auto">
        {title}
      </h1>
      {subtitle && (
        <p class="font-body text-lg text-muted max-w-lg leading-relaxed">
          {subtitle}
        </p>
      )}
      <div class="flex flex-wrap gap-3">
        <slot />
      </div>
    </div>

    <!-- Columna visual: 45% — placeholder CSS cálido (solo CSS, sin etiqueta img) -->
    <div class="flex items-center justify-center">
      <slot name="media">
        <div class="w-full aspect-[4/3] rounded bg-primary/10 flex items-end p-6" aria-hidden="true">
          <div class="flex flex-col gap-2 w-full">
            <div class="h-2 rounded-full bg-primary/20 w-3/4"></div>
            <div class="h-2 rounded-full bg-secondary/20 w-1/2"></div>
            <div class="h-2 rounded-full bg-primary/10 w-2/3"></div>
          </div>
        </div>
      </slot>
    </div>
  </div>
</div>
