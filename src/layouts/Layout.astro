---
import '../styles/global.css'
import ThemeScript from '../components/ui/ThemeScript.astro'
import ThemeToggle from '../components/ui/ThemeToggle.astro'
import {
  isActivePath,
  primaryNavLinks,
  quoteCta,
  footerNavLinks,
} from '../lib/nav'

interface Props {
  title: string
}

const { title } = Astro.props

const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-bg text-ink font-body">
    <!-- Barra de navegación -->
    <nav class="border-b border-border bg-surface/80 backdrop-blur-sm sticky top-0 z-50" aria-label="Navegación principal">
      <div class="container mx-auto px-4 py-4 flex items-center justify-between gap-4">
        <!-- Marca Nido -->
        <a
          href="/"
          class="font-display text-xl text-ink hover:text-primary transition-colors rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2"
          aria-label="Nido — inicio"
        >
          Nido
        </a>

        <!-- Navegación de escritorio -->
        <ul class="hidden md:flex gap-6 items-center">
          {primaryNavLinks.map(({ href, label }) => {
            const active = isActivePath(currentPath, href)
            return (
              <li>
                <a
                  href={href}
                  aria-current={active ? 'page' : undefined}
                  class={
                    (active
                      ? 'text-primary border-b-2 border-primary pb-0.5'
                      : 'text-ink hover:text-primary border-b-2 border-transparent pb-0.5') +
                    ' text-sm font-medium transition-colors rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2'
                  }
                >
                  {label}
                </a>
              </li>
            )
          })}
          <li class="flex items-center">
            <ThemeToggle />
          </li>
          <li>
            <a
              href="/admin"
              class="text-muted hover:text-primary text-sm font-medium transition-colors rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2"
            >
              Admin
            </a>
          </li>
          <li>
            <a
              href={quoteCta.href}
              aria-current={isActivePath(currentPath, quoteCta.href) ? 'page' : undefined}
              class="inline-flex items-center justify-center rounded bg-primary text-surface px-5 py-2 text-sm font-medium transition-all duration-200 hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2"
            >
              {quoteCta.label}
            </a>
          </li>
        </ul>

        <!-- Controles móviles (toggle de tema + hamburguesa) -->
        <div class="flex items-center gap-2 md:hidden">
          <ThemeToggle />
          <button
            id="nav-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Abrir menú"
            class="rounded p-2 text-ink hover:text-primary hover:bg-bg/60 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50"
          >
            <!-- Ícono hamburguesa -->
            <svg
              id="icon-open"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
            <!-- Ícono cierre -->
            <svg
              id="icon-close"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              style="display:none"
            >
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Menú móvil -->
      <div id="mobile-menu" hidden class="md:hidden border-t border-border bg-surface">
        <ul class="container mx-auto px-4 py-4 flex flex-col gap-1">
          {primaryNavLinks.map(({ href, label }) => {
            const active = isActivePath(currentPath, href)
            return (
              <li>
                <a
                  href={href}
                  aria-current={active ? 'page' : undefined}
                  class={
                    (active
                      ? 'text-primary border-primary'
                      : 'text-ink hover:text-primary border-transparent') +
                    ' block font-medium text-sm border-l-2 pl-3 py-2 rounded-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50'
                  }
                  data-mobile-link
                >
                  {label}
                </a>
              </li>
            )
          })}
          <li>
            <a
              href="/admin"
              class="block text-muted hover:text-primary font-medium text-sm border-l-2 border-transparent pl-3 py-2 rounded-sm transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50"
              data-mobile-link
            >
              Admin
            </a>
          </li>
          <li class="pt-3">
            <a
              href={quoteCta.href}
              aria-current={isActivePath(currentPath, quoteCta.href) ? 'page' : undefined}
              class="block text-center rounded bg-primary text-surface px-5 py-2.5 text-sm font-medium transition-all duration-200 hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2"
              data-mobile-link
            >
              {quoteCta.label}
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Contenido principal -->
    <main class="min-h-screen">
      <slot />
    </main>

    <!-- Pie de página de 3 columnas -->
    <footer class="border-t border-border bg-ink text-bg">
      <div class="container mx-auto px-4 py-12">
        <div class="grid sm:grid-cols-3 gap-8">
          <!-- Columna 1: Marca -->
          <div>
            <p class="font-display text-xl mb-2">Nido</p>
            <p class="text-bg/70 text-sm leading-relaxed">
              Construcción sustentable con paneles SIP y casas prefabricadas de alta calidad.
            </p>
          </div>

          <!-- Columna 2: Navegación -->
          <div>
            <p class="font-semibold text-sm uppercase tracking-wide mb-4 text-bg/70">Navegación</p>
            <ul class="flex flex-col gap-2">
              {footerNavLinks.map(({ href, label }) => (
                <li>
                  <a
                    href={href}
                    class="text-sm text-bg/70 hover:text-bg transition-colors rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-bg/40"
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Columna 3: Contacto -->
          <div>
            <p class="font-semibold text-sm uppercase tracking-wide mb-4 text-bg/70">Contacto</p>
            <ul class="flex flex-col gap-2 text-sm text-bg/70">
              <li>contacto@nido.cl</li>
              <li>+56 9 0000 0000</li>
              <li>Santiago, Chile</li>
            </ul>
          </div>
        </div>

        <div class="border-t border-bg/10 mt-10 pt-6 text-center">
          <p class="text-bg/50 text-xs">&copy; {new Date().getFullYear()} Nido. Todos los derechos reservados.</p>
        </div>
      </div>
    </footer>

    <!-- Script de hamburguesa (sin compartir variables con ThemeToggle) -->
    <script>
      const navToggle = document.getElementById('nav-toggle')
      const mobileMenu = document.getElementById('mobile-menu')
      const iconOpen = document.getElementById('icon-open')
      const iconClose = document.getElementById('icon-close')
      const mobileLinks = document.querySelectorAll('[data-mobile-link]')

      function openMenu(): void {
        if (!mobileMenu || !navToggle || !iconOpen || !iconClose) return
        mobileMenu.removeAttribute('hidden')
        navToggle.setAttribute('aria-expanded', 'true')
        navToggle.setAttribute('aria-label', 'Cerrar menú')
        iconOpen.style.display = 'none'
        iconClose.style.display = 'block'
      }

      function closeMenu(): void {
        if (!mobileMenu || !navToggle || !iconOpen || !iconClose) return
        mobileMenu.setAttribute('hidden', '')
        navToggle.setAttribute('aria-expanded', 'false')
        navToggle.setAttribute('aria-label', 'Abrir menú')
        iconOpen.style.display = 'block'
        iconClose.style.display = 'none'
      }

      function isMenuOpen(): boolean {
        return navToggle?.getAttribute('aria-expanded') === 'true'
      }

      navToggle?.addEventListener('click', () => {
        if (isMenuOpen()) {
          closeMenu()
        } else {
          openMenu()
        }
      })

      mobileLinks.forEach((link) => {
        link.addEventListener('click', closeMenu)
      })

      // Cierra con Escape y devuelve el foco al botón que abrió el menú.
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && isMenuOpen()) {
          closeMenu()
          navToggle?.focus()
        }
      })

      // Cierra al tocar fuera de la barra de navegación.
      document.addEventListener('click', (event) => {
        if (!isMenuOpen()) return
        const target = event.target as Node | null
        const nav = navToggle?.closest('nav')
        if (nav && target && !nav.contains(target)) {
          closeMenu()
        }
      })
    </script>
  </body>
</html>
