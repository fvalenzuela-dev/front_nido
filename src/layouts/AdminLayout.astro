---
import '../styles/global.css'
import ThemeScript from '../components/ui/ThemeScript.astro'
import ThemeToggle from '../components/ui/ThemeToggle.astro'

interface Props {
  title: string
}

const { title } = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-bg text-ink font-body">
    <div class="flex min-h-screen">
      <!-- Admin sidebar -->
      <aside class="w-64 bg-surface border-r border-bg/50 flex flex-col">
        <div class="p-6 border-b border-bg/50">
          <h1 class="font-display text-lg text-ink">Panel Admin</h1>
          <p class="text-muted text-xs mt-1">Nido — Gestión</p>
        </div>
        <nav class="flex-1 p-4">
          <ul class="space-y-1">
            <li>
              <a
                href="/admin"
                class="block px-3 py-2 rounded text-sm text-ink hover:text-primary hover:bg-bg transition-colors"
              >
                Dashboard
              </a>
            </li>
            <li>
              <a
                href="/admin/productos"
                class="block px-3 py-2 rounded text-sm text-ink hover:text-primary hover:bg-bg transition-colors"
              >
                Paneles SIP
              </a>
            </li>
            <li>
              <a
                href="/admin/casas"
                class="block px-3 py-2 rounded text-sm text-ink hover:text-primary hover:bg-bg transition-colors"
              >
                Casas
              </a>
            </li>
          </ul>
        </nav>
      </aside>

      <!-- Main content -->
      <div class="flex-1 flex flex-col">
        <!-- Topbar: acciones globales (tema, sesión) -->
        <header class="border-b border-bg/50 bg-surface/80 backdrop-blur-sm">
          <div class="flex items-center justify-between px-8 py-4">
            <p class="font-display text-ink">Nido · Gestión</p>
            <div class="flex items-center gap-2">
              <ThemeToggle />
              <!-- Sign out stub — functionality deferred to auth phase -->
              <button
                type="button"
                class="px-3 py-2 text-sm text-muted hover:text-ink rounded border border-bg/50 hover:bg-bg transition-colors"
              >
                Cerrar sesión
              </button>
            </div>
          </div>
        </header>
        <main class="flex-1 p-8">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
