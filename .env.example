# Supabase — public (safe with RLS enabled)
PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase — private (NEVER expose to the client / islands)
SUPABASE_SERVICE_KEY=eyJ...

# Site URL
PUBLIC_SITE_URL=https://tu-dominio.com

# Admin auth bypass — local dev ONLY. NEVER set in production/preview.
# Skips ALL /admin auth checks when exactly "true". Default OFF (unset).
# Setting this in Vercel or any public environment is a critical security risk.
SKIP_ADMIN_AUTH=

